# GitHub Webhook Secret — generate: openssl rand -hex 32
WEBHOOK_SECRET=your-32-char-hex-secret

# Voyage AI embeddings (needed in Phase 3+ for README/blog embeddings, Phase 4 RAG) — https://dash.voyageai.com
VOYAGE_API_KEY=pa-...

# Cloudflare Analytics (optional)
CLOUDFLARE_ANALYTICS_TOKEN=
