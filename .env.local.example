# Supabase — https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# GitHub Webhook Secret — generate: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your-32-char-hex-secret

# Voyage AI embeddings (needed in Phase 4) — https://dash.voyageai.com
VOYAGE_API_KEY=pa-...

# Resend contact form emails (optional) — https://resend.com/api-keys
RESEND_API_KEY=re_...

# Cloudflare Analytics (optional)
CLOUDFLARE_ANALYTICS_TOKEN=
